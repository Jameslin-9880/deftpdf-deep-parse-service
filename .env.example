DEEP_PARSE_HOST=127.0.0.1
DEEP_PARSE_PORT=18080
DEEP_PARSE_VENV_DIR=/opt/deftpdf-deep-parse/.venv
MINERU_MODEL_SOURCE=modelscope
MINERU_LOG_LEVEL=INFO
MINERU_API_ENABLE_FASTAPI_DOCS=0
MINERU_API_ENABLE_VLM_PRELOAD=false
MINERU_API_OUTPUT_ROOT=/var/lib/deftpdf-deep-parse/output
MINERU_API_MAX_CONCURRENT_REQUESTS=1
